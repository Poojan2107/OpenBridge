# ─── Required ────────────────────────────────────────────────

# Gemini API key for AI features (code review, issue mapping, etc.)
# Get one free at https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=

# ─── Database ────────────────────────────────────────────────

# SQLite (default, no setup required)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@host:5432/openbridge"

# ─── GitHub OAuth (Optional) ─────────────────────────────────

# Real GitHub OAuth integration. Falls back to simulated auth if blank.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Security ────────────────────────────────────────────────

# 32-character passphrase for AES-256-CBC token encryption.
# Auto-generated on boot if left blank.
ENCRYPTION_KEY=

# ─── App ─────────────────────────────────────────────────────

APP_URL="http://localhost:3000"
